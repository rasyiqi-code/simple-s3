{
  "name": "simple-s3",
  "version": "1.0.0",
  "description": "Internal Storage API Service menggunakan Express, Multer, dan Sharp",
  "main": "dist/src/index.js",
  "type": "module",
  "packageManager": "bun@1.2.16",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prestart": "tsc",
    "start": "node dist/src/index.js",
    "test": "NODE_ENV=test vitest run",
    "show-key": "tsx src/cli/manage-key.ts",
    "reset-key": "tsx src/cli/manage-key.ts --reset"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.9.3",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.15.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}
