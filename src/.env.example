# Konfigurasi Server
PORT=3000
NODE_ENV=development

# Keamanan (Master API Key untuk akses administratif: buat bucket, kelola API key, dll)
API_KEY=your_secure_master_api_key_here

# Konfigurasi Storage
UPLOAD_DIR=uploads
# 50MB dalam bytes (50 * 1024 * 1024)
MAX_FILE_SIZE=52428800
# Ekstensi file yang diizinkan (pisahkan dengan koma)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,mp4,zip,docx,xlsx

# -------------------------------------------------------------------
# Alur penggunaan:
# 1. Set API_KEY di atas sebagai master key (hanya untuk admin)
# 2. Login ke dashboard admin dengan master key tersebut
# 3. Buat bucket via POST /api/admin/buckets  { name: "avatars" }
# 4. Buat API key terikat ke bucket via POST /api/admin/keys
#    { name: "App X Key", bucket_name: "avatars" }
# 5. Gunakan API key dari langkah 4 untuk upload ke bucket tersebut
#    POST /api/upload  dengan header x-api-key: sk_...
# 6. File dapat diakses publik via GET /file/:bucket/:filename
# -------------------------------------------------------------------
