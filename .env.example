# Konfigurasi Server
PORT=3000
NODE_ENV=development

# Keamanan (API Key untuk autentikasi)
API_KEY=your_secure_static_api_key_here

# Konfigurasi Storage & Database
# Tip: Gunakan path absolut agar data tetap aman saat redeploy.
# Contoh untuk Shared Hosting (Hostinger):
# UPLOAD_DIR=/home/u411274507/domains/s3.crediblemark.com/uploads
# DATABASE_DIR=/home/u411274507/domains/s3.crediblemark.com/data
# BACKUP_DIR=/home/u411274507/domains/s3.crediblemark.com/backups
UPLOAD_DIR=uploads
DATABASE_DIR=data
# 50MB dalam bytes (50 * 1024 * 1024)
MAX_FILE_SIZE=52428800
# Ekstensi file yang diizinkan (pisahkan dengan koma)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,mp4,zip,docx,xlsx
