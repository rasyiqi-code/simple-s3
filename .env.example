# Konfigurasi Server
PORT=3000
NODE_ENV=development

# Keamanan (API Key untuk autentikasi)
API_KEY=your_secure_static_api_key_here

# Konfigurasi Storage
UPLOAD_DIR=uploads
# 50MB dalam bytes (50 * 1024 * 1024)
MAX_FILE_SIZE=52428800
# Ekstensi file yang diizinkan (pisahkan dengan koma)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,mp4,zip,docx,xlsx
